# ============================================================
# Okta Organization Base URL
# ============================================================
OKTA_ORG_URL=https://your-org.oktapreview.com

# ============================================================
# HUMAN IDENTITY (HI) Flow — Authorization Code + PKCE
# Register http://localhost:3000/api/auth/callback as redirect URI
# ============================================================
HI_CLIENT_ID=your_hi_client_id
HI_CLIENT_SECRET=your_hi_client_secret
HI_AUTH_SERVER_ID=your_auth_server_id
HI_SCOPE=openid agent.invoke
HI_RESOURCE=https://progear.com/sales
HI_CALLBACK_URL=http://localhost:3000/api/auth/callback

# ============================================================
# STEP 1: Service Client — Client Credentials Grant
# ProGearSales Service Client authenticates at ProGear Custom AS
# ============================================================
STEP1_AUTH_SERVER_ID=your_auth_server_id
STEP1_CLIENT_ID=your_client_id
STEP1_CLIENT_SECRET=your_client_secret
STEP1_SCOPE=agent.invoke
STEP1_RESOURCE=https://progear.com/sales

# ============================================================
# STEP 2: ProGearSales Agent — Token Exchange → id-jag
# Exchanges T1 at Org AS for an id-jag targeting ProGearInventory AS
# ============================================================
STEP2_CLIENT_ID=your_progear_sales_client_id
STEP2_PRIVATE_KEY_JWK={"alg":"RS256","d":"...","e":"AQAB","kty":"RSA","n":"...","kid":"your_kid","use":"sig"}
STEP2_AUDIENCE=https://your-org.oktapreview.com/oauth2/your_inventory_as_id
STEP2_RESOURCE=https://progear.com/inventory
STEP2_SCOPE=agent.invoke

# ============================================================
# STEP 3: ProGearSales Agent — JWT Bearer Grant
# Exchanges T2 (id-jag) at ProGearInventory AS for A2A Access Token
# ============================================================
STEP3_AUTH_SERVER_ID=your_inventory_as_id
STEP3_CLIENT_ID=your_progear_sales_client_id_at_inventory_as
STEP3_PRIVATE_KEY_JWK={"alg":"RS256","d":"...","e":"AQAB","kty":"RSA","n":"...","kid":"your_kid","use":"sig"}

# ============================================================
# STEP 4: ProGearInventory Agent — Token Exchange → id-jag
# Exchanges T3 at Org AS for an id-jag targeting InventoryMCP AS
# ============================================================
STEP4_CLIENT_ID=your_progear_inventory_client_id
STEP4_PRIVATE_KEY_JWK={"alg":"RS256","d":"...","e":"AQAB","kty":"RSA","n":"...","kid":"your_kid","use":"sig"}
STEP4_AUDIENCE=https://your-org.oktapreview.com/oauth2/your_inventorymcp_as_id
STEP4_SCOPE=agent.invoke

# ============================================================
# STEP 5: ProGearInventory Agent — JWT Bearer Grant
# Exchanges T4 (id-jag) at InventoryMCP AS for final Access Token
# ============================================================
STEP5_AUTH_SERVER_ID=your_inventorymcp_as_id
STEP5_CLIENT_ID=your_progear_inventory_client_id
STEP5_PRIVATE_KEY_JWK={"alg":"RS256","d":"...","e":"AQAB","kty":"RSA","n":"...","kid":"your_kid","use":"sig"}
